@model IEnumerable<Citas_App.Domain.Models.Medico>
<h2>Nuestros Médicos</h2>
<table class="table">
    <thead><tr><th>Nombre</th><th>Especialidad</th><th>Acciones</th></tr></thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Nombre @item.Apellido</td>
                <td>@item.Especialidad</td>
                <td><a asp-action="Detalle" asp-route-id="@item.Id" class="btn btn-info">Detalles</a></td>
            </tr>
        }
    </tbody>
</table>
