@model IEnumerable<Citas_App.Domain.Models.Paciente>
<h2>Lista de Pacientes</h2>
<table class="table">
    <thead>
        <tr><th>Nombre Completo</th><th>Email</th><th>Acciones</th></tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Nombre @item.Apellido</td>
                <td>@item.Email</td>
                <td><a asp-action="Detalle" asp-route-id="@item.Id" class="btn btn-info">Ver Detalle</a></td>
            </tr>
        }
    </tbody>
</table>