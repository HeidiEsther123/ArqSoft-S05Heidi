@model IEnumerable<Citas_App.Models.Cita>

<h2>Citas de: @ViewBag.PacienteSeleccionado</h2>

<table class="table">
    <thead>
        <tr>
            <th>Fecha/Hora</th>
            <th>Médico</th>
            <th>Motivo</th>
            <th>Estado</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            var med = (ViewBag.Medicos as List<Citas_App.Models.Medico>)?.FirstOrDefault(m => m.Id == item.MedicoId);
            <tr>
                <td>@item.Fecha @item.Hora</td>
                <td>@(med != null ? med.Nombre : "No encontrado")</td>
                <td>@item.Motivo</td>
                <td>@item.Estado</td>
            </tr>
        }
    </tbody>
</table>

<a asp-controller="Paciente" asp-action="Index" class="btn btn-secondary">Volver a Pacientes</a>